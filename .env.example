# Copy this file to ".env" and fill in your values.
# The app runs WITHOUT a Stripe key (it uses a built-in mock processor),
# so you can try everything first, then add real test keys when ready.

# Server
PORT=4242

# Database. Leave blank to use the built-in JSON file store (zero setup).
# Set a PostgreSQL connection string to use Postgres instead, e.g.:
# DATABASE_URL=postgres://user:password@localhost:5432/platepoint
DATABASE_URL=
# Set to "true" if your Postgres host requires SSL (most cloud providers do).
DATABASE_SSL=

# ---- Payments: choose your processor ----
# PAYMENT_GATEWAY selects the active processor: stripe | fiserv | tsys | valor | globalpayments | mock
# Leave blank to auto-detect (Stripe if its key is set, otherwise mock).
PAYMENT_GATEWAY=

# Stripe TEST keys — get these free at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Fiserv (Commerce Hub / CardConnect) — requires a merchant account + certification.
FISERV_API_KEY=
FISERV_API_SECRET=
FISERV_MERCHANT_ID=
FISERV_ENV=cert

# TSYS (legacy Genius/TransIT) — requires a merchant account + certification.
TSYS_MERCHANT_ID=
TSYS_TRANSACTION_KEY=
TSYS_DEVICE_ID=
TSYS_ENV=test

# Global Payments — GP API (unified commerce). Get sandbox creds at
# https://developer.globalpay.com. PAYMENT_GATEWAY=globalpayments (aliases: global, gp).
GP_API_APP_ID=
GP_API_APP_KEY=
GP_API_ENV=sandbox
GP_API_ACCOUNT_NAME=

# Tax rate applied to subtotals (decimal, e.g. 0.0825 = 8.25%)
TAX_RATE=0.0825

# Secret used to sign login tokens. Use a long random string in production.
JWT_SECRET=change-this-to-a-long-random-secret

# Stripe webhook signing secret (starts with whsec_). Get it from
# https://dashboard.stripe.com/test/webhooks after adding an endpoint,
# or from the Stripe CLI when running `stripe listen`. Leave blank to skip verification in dev.
STRIPE_WEBHOOK_SECRET=

# Delivery integrations (DoorDash / Uber Eats / Grubhub / aggregators).
# Secret key that incoming-order webhooks must send as the `x-integration-key` header.
# Generate a long random string. Leave blank to disable the webhook (the in-app
# "simulate order" button still works for managers without it).
INTEGRATION_API_KEY=
